loquer certains thèmes pour empêcher que Chrome les partage avec les sites, et désactiver les thèmes d'annonces à tout moment dans les paramètres Chrome. Pour savoir comment Google protège vos données, lisez nos règles de confidentialité."}},"profile":{"avatar_index":26,"content_settings":{"did_migrate_adaptive_notification_quieting_to_cpss":true,"disable_quiet_permission_ui_time":{"notifications":"13374409434422885"},"enable_cpss":{"notifications":true},"enable_quiet_permission_ui":{"notifications":false},"enable_quiet_permission_ui_enabling_method":{"notifications":1},"exceptions":{"3pcd_heuristics_grants":{},"3pcd_support":{},"abusive_notification_permissions":{},"access_to_get_all_screens_media_in_session":{},"accessibility_events":{},"anti_abuse":{},"app_banner":{"https://www.youtube.com:443,*":{"last_modified":"13375964610482068","setting":{"https://www.youtube.com/":{"next_install_text_animation":{"delay":"691200000000","last_shown":"13375964610482053"}},"https://www.youtube.com/?feature=ytca":{"couldShowBannerEvents":1.337440952574214e+16}}}},"ar":{},"auto_picture_in_picture":{},"auto_select_certificate":{},"automatic_downloads":{},"automatic_fullscreen":{},"autoplay":{},"background_sync":{},"bluetooth_chooser_data":{},"bluetooth_guard":{},"bluetooth_scanning":{},"camera_pan_tilt_zoom":{},"captured_surface_control":{},"client_hints":{"https://accounts.google.be:443,*":{"last_modified":"13374409504277637","setting":{"client_hints":[9,10,11,13,14,16,23,25,29]}},"https://accounts.google.com:443,*":{"last_modified":"13374409434728756","setting":{"client_hints":[9,10,11,13,14,16,23,25,29]}},"https://accounts.youtube.com:443,*":{"last_modified":"13374409504141109","setting":{"client_hints":[9,10,11,13,14,16,23,25,29]}},"https://www.google.com:443,*":{"last_modified":"13375737924577226","setting":{"client_hints":[9,10,11,13,14,15,16,23,25,29]}},"https://www.googleadservices.com:443,*":{"last_modified":"13375728233659565","setting":{"client_hints":[9,10,11,13,14,16,